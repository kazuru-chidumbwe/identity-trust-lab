{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kazuru-chidumbwe/identity-trust-lab/schemas/matrix.schema.json",
  "title": "OIDC deviation matrix",
  "description": "OIDC deviation matrix. Cells use a fixed verdict enum — not free-text-only.",
  "type": "object",
  "required": ["matrix_id", "profile_id", "idp_versions", "rows", "created_utc"],
  "properties": {
    "matrix_id": { "type": "string" },
    "profile_id": { "type": "string" },
    "git_tag": { "type": "string" },
    "created_utc": { "type": "string", "format": "date-time" },
    "idp_versions": {
      "type": "object",
      "description": "Map of driver id → pinned version/image string",
      "additionalProperties": { "type": "string" },
      "minProperties": 1
    },
    "config_equivalence": {
      "type": "object",
      "description": "Checklist outcomes before rows may use implementation_drift",
      "properties": {
        "passed": { "type": "boolean" },
        "checklist_id": { "type": "string" },
        "checklist_path": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/row" }
    }
  },
  "$defs": {
    "verdict": {
      "type": "string",
      "enum": [
        "same",
        "config_drift",
        "implementation_drift",
        "undefined",
        "harness_error"
      ]
    },
    "observed": {
      "type": "object",
      "description": "Normalized fields only (see docs/methodology.md)",
      "additionalProperties": true
    },
    "row": {
      "type": "object",
      "required": ["feature", "expected", "observed", "verdict"],
      "properties": {
        "feature": { "type": "string" },
        "expected": { "type": "string" },
        "observed": {
          "type": "object",
          "description": "Map of driver id → normalized observation object",
          "additionalProperties": { "$ref": "#/$defs/observed" },
          "minProperties": 1
        },
        "verdict": { "$ref": "#/$defs/verdict" },
        "notes": { "type": "string" },
        "impact": {
          "type": "string",
          "description": "Required when verdict is not same or harness_error"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
