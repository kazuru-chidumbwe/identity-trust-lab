{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kazuru-chidumbwe/identity-trust-lab/schemas/profile.schema.json",
  "title": "OIDC measurement profile",
  "type": "object",
  "required": ["id", "version", "flow", "spine", "client", "assertions"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "description": { "type": "string" },
    "flow": {
      "type": "string",
      "enum": ["authorization_code_pkce"]
    },
    "spine": {
      "type": "string",
      "enum": ["refresh_token"]
    },
    "client": {
      "type": "object",
      "required": ["client_id"],
      "properties": {
        "client_id": { "type": "string" },
        "pkce": { "type": "boolean", "default": true },
        "offline_access": { "type": "boolean", "default": false }
      }
    },
    "perturbations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["refresh_reuse", "refresh_rotate", "clock_skew", "none"]
          },
          "params": { "type": "object" }
        }
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["feature", "expected"],
        "properties": {
          "feature": { "type": "string" },
          "expected": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
